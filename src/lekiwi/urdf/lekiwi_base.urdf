<?xml version="1.0" encoding="utf-8"?>
<robot name="lekiwi">

  <material name="blue"><color rgba="0 0 0.8 1"/></material>
  <material name="black"><color rgba="0 0 0 1"/></material>

  <link name="base_link">
    <visual>
      <geometry><box size="0.2 0.2 0.1"/></geometry>
      <material name="blue"/>
    </visual>
  </link>

  <link name="left_wheel_link">
    <visual>
      <geometry><cylinder radius="0.03" length="0.02"/></geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="left_wheel_drive" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="0.1 0.1 0" rpy="-1.5708 0 0"/> 
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="rear_wheel_drive" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="0 -0.1 0" rpy="-1.5708 0 0"/> 
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="right_wheel_drive" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="-0.1 0.1 0" rpy="-1.5708 0 0"/> 
    <axis xyz="0 0 1"/>
  </joint>


  <!-- ✅✅✅ 这里是正确的硬件参数配置 -->
  <ros2_control name="lekiwi_hardware" type="system">
    <hardware>
      <plugin>lekiwi_controller/LekiwiBase</plugin> 

      <!-- ✅✅✅ 你的参数全部在这里！ -->
      <param name="use_serial">true</param>
      <param name="serial_port">/dev/ttyACM0</param>
      <param name="serial_baud">1000000</param>
    </hardware>

    <joint name="left_wheel_drive">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="rear_wheel_drive">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="right_wheel_drive">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

</robot>
